{
  "id": "fullstack",
  "framework": "any",
  "schema_version": 1,
  "rules": [
    {
      "id": "mixed-content-egress",
      "severity": "warning",
      "message": "Plain-http URL literal — mixed content/MITM risk. Use https. Suppress a vetted case with `// mixed-content-ok`.",
      "suppress_marker": "mixed-content-ok",
      "matcher": {
        "type": "line-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "line_pattern": "['\"]http://[^'\"\\s]",
        "exclude_pattern": "(?i)(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|//192\\.168\\.|//10\\.[0-9]|//172\\.(1[6-9]|2[0-9]|3[01])\\.|xmlns|w3\\.org|schemas?\\.|\\.xsd)",
        "skip_comment_lines": true
      }
    },
    {
      "id": "localhost-egress-committed",
      "severity": "warning",
      "message": "Committed localhost/private-IP endpoint — breaks outside the dev machine. Move it to env/config; if this file is genuinely dev-only, exclude it via config instead. Suppress a vetted case with `// localhost-ok`.",
      "suppress_marker": "localhost-ok",
      "matcher": {
        "type": "line-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "line_pattern": "['\"]https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|192\\.168\\.[0-9]{1,3}\\.[0-9]{1,3}|10\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}|172\\.(1[6-9]|2[0-9]|3[01])\\.[0-9]{1,3}\\.[0-9]{1,3})",
        "exclude_pattern": "(?i)(process\\.env|getEnv\\(|IS_PRODUCTION).*(\\|\\||\\?\\?|\\?)|new\\s+URL\\s*\\(|[!=]==?\\s*[\"'`]https?://localhost",
        "skip_comment_lines": true
      }
    },
    {
      "id": "get-with-body",
      "severity": "warning",
      "message": "A GET request carrying a body (`method: 'get'` alongside `body:` in the same function) — servers/proxies may silently drop the body on a GET, so data the caller thinks it's sending never arrives. Use POST (or another body-bearing method) or move the data to query params. Suppress a vetted case with `// get-body-ok`.",
      "suppress_marker": "get-body-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "patterns": [
          { "pattern": "(?i)method\\s*:\\s*['\"]get['\"]", "label": "get-method" },
          { "pattern": "\\bbody\\s*:", "label": "body" }
        ],
        "trigger": "body"
      }
    },
    {
      "id": "ws-no-auth",
      "severity": "info",
      "message": "WebSocket opened/upgraded (`new WebSocket(...)`/`.upgrade(...)`) with no auth material (`token`/`auth`/`session`/`cookie`/`jwt`) in the same function — an unauthenticated realtime channel lets anyone who can reach the socket connect. Attach a token/cookie/session credential when opening or upgrading. Suppress a vetted case with `// ws-auth-ok`.",
      "suppress_marker": "ws-auth-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "patterns": [
          { "pattern": "new\\s+WebSocket\\s*\\(|\\.upgrade\\s*\\(", "label": "ws" }
        ],
        "trigger": "ws",
        "absent": [
          { "pattern": "(?i)\\b(token|auth|session|cookie|jwt)\\b", "label": "auth" }
        ]
      }
    }
  ]
}

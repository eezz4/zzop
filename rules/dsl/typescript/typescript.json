{
  "id": "typescript",
  "framework": "any",
  "schema_version": 1,
  "rules": [
    {
      "id": "no-explicit-any",
      "severity": "info",
      "message": "`any` type used — defeats TypeScript's type checking for this value. Replace with a concrete type, a generic parameter, or `unknown` plus a type guard if the shape is genuinely dynamic. Suppress a vetted case with `// any-ok`.",
      "suppress_marker": "any-ok",
      "matcher": {
        "type": "line-scan",
        "file_pattern": "(?i)\\.(ts|tsx)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "line_pattern": ":\\s*any\\b|\\bas\\s+any\\b|<any\\b|\\bany\\[\\]",
        "snippet_max": 160
      }
    },
    {
      "id": "as-cast",
      "severity": "info",
      "message": "`as any` / `as unknown as` cast — a hard escape from type checking (`as any` disables it, `as unknown as X` force-casts through an incompatible type). Prefer a type guard, a properly-typed API, or `unknown` plus a narrowing check. Plain `as X` to a compatible type is not flagged. Suppress a vetted case with `// as-ok`.",
      "suppress_marker": "as-ok",
      "matcher": {
        "type": "line-scan",
        "file_pattern": "(?i)\\.(ts|tsx)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "line_pattern": "\\bas\\s+any\\b|\\bas\\s+unknown\\s+as\\b",
        "exclude_pattern": "^\\s*import\\b|\\bas\\s+const\\b|\\bas\\s*=",
        "skip_comment_lines": true,
        "snippet_max": 160
      }
    },
    {
      "id": "unhandled-promise-use-effect",
      "severity": "warning",
      "message": "useEffect callback declared async — React ignores the returned Promise and no cleanup function can be returned; a rejection becomes unhandled. Move the async work into an inner async function or IIFE: `useEffect(() => { void doAsync(); }, deps)`. Suppress a vetted case with `// unhandled-promise-ok`.",
      "suppress_marker": "unhandled-promise-ok",
      "matcher": {
        "type": "line-scan",
        "file_pattern": "(?i)\\.(ts|tsx)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "line_pattern": "\\buseEffect\\s*\\(\\s*async\\b",
        "snippet_max": 160
      }
    },
    {
      "id": "async-handler-no-try",
      "severity": "warning",
      "message": "An `on<Event>={async ...}` JSX handler (or `on<Event>: async ...` handler-map property) has an `await` but no try/catch — a rejection becomes an unhandled promise rejection. Add try/catch (or `.catch()`) inside the handler. Suppress a vetted case with `// async-handler-ok`.",
      "suppress_marker": "async-handler-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.(ts|tsx)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "require_file": "\\bawait\\b",
        "patterns": [
          { "pattern": "\\bon[A-Z]\\w*\\s*[:=]\\s*\\{?\\s*async\\b", "label": "handler" },
          { "pattern": "\\bawait\\b", "label": "await" }
        ],
        "trigger": "handler",
        "absent": [
          { "pattern": "\\btry\\s*\\{", "label": "try-guard" }
        ],
        "snippet_max": 160
      }
    }
  ]
}

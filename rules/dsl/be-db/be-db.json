{
  "id": "be-db",
  "schema_version": 1,
  "rules": [
    {
      "id": "update-delete-no-where",
      "severity": "critical",
      "message": "`updateMany`/`deleteMany` called with no `where:` clause anywhere in the enclosing function — a whole-table write, not a filtered subset. Add a `where:` filter that scopes the write, or mark a genuinely full-table write explicitly. Suppress a vetted case with `// no-where-ok`.",
      "suppress_marker": "no-where-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "patterns": [
          { "pattern": "\\.(?:updateMany|deleteMany)\\s*\\(", "label": "bulk-write" }
        ],
        "trigger": "bulk-write",
        "absent": [
          { "pattern": "\\bwhere\\s*:", "label": "where-clause" },
          { "pattern": "\\.(?:updateMany|deleteMany)\\s*\\(\\s*(?:\\([^)]*\\)\\s*=>|[A-Za-z_$][\\w$]*\\s*=>|function\\s*\\()", "label": "predicate-fn-arg" }
        ],
        "snippet_max": 160
      }
    },
    {
      "id": "pagination-no-orderby",
      "severity": "warning",
      "message": "`skip`/`take` pagination used with no `orderBy` in the enclosing function — without a stable sort, page boundaries can shift between requests (rows skipped or duplicated across pages). Add an `orderBy:` on a unique or otherwise stable column. Suppress a vetted case with `// pagination-ok`.",
      "suppress_marker": "pagination-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "patterns": [
          { "pattern": "\\b(?:skip|take)\\s*:", "label": "pagination" },
          { "pattern": "\\.findMany\\s*\\(", "label": "find-many" }
        ],
        "trigger": "pagination",
        "absent": [
          { "pattern": "\\borderBy\\s*:", "label": "order-by" }
        ],
        "snippet_max": 160
      }
    },
    {
      "id": "client-per-request",
      "severity": "warning",
      "message": "`new PrismaClient()` constructed inside a function that looks like a request handler (references `req`/`res`/`ctx`/`request`/`reply`) — a fresh client per request exhausts the database connection pool under load. Hoist a single client to a module-level singleton instead. Suppress a vetted case with `// prisma-client-ok`.",
      "suppress_marker": "prisma-client-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "patterns": [
          { "pattern": "\\bnew\\s+PrismaClient\\s*\\(", "label": "new-client" },
          { "pattern": "\\b(?:req|res|ctx|request|reply)\\b", "label": "handler-context" }
        ],
        "trigger": "new-client",
        "snippet_max": 160
      }
    },
    {
      "id": "external-call-in-tx",
      "severity": "warning",
      "message": "A network call (`fetch`/`axios`/`got`) appears in the same function as a `$transaction(` — holding a database transaction open across a network round-trip extends lock hold time, and stalls with it if the external call stalls. Move the network call outside the `$transaction` block. Suppress a vetted case with `// tx-egress-ok`.",
      "suppress_marker": "tx-egress-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "patterns": [
          { "pattern": "\\$transaction\\s*\\(", "label": "transaction" },
          { "pattern": "\\b(?:fetch|axios|got)\\s*[.(]", "label": "egress" }
        ],
        "trigger": "egress",
        "snippet_max": 160
      }
    },
    {
      "id": "unawaited-write",
      "severity": "warning",
      "message": "A database write (`create`/`update`/`delete`/`upsert`) on a DB-client-shaped receiver (`prisma`/`db`/`tx`/`client`/`repo`) whose promise is neither awaited, returned, nor chained — a failed write looks identical to a successful one. Await the call (or return it, or attach `.then()`/`.catch()`). Suppress a vetted case with `// unawaited-ok`.",
      "suppress_marker": "unawaited-ok",
      "matcher": {
        "type": "line-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "line_pattern": "\\b(prisma|db|tx|client|repo(sitory|sitories)?s?)\\.(\\w+\\.)?(create|update|delete|upsert)\\s*\\(",
        "exclude_pattern": "\\b(await|return)\\b|\\.then\\b|=\\s*\\w|=>",
        "snippet_max": 160
      }
    },
    {
      "id": "unbounded-user-limit",
      "severity": "warning",
      "message": "A `take`/`limit` pagination size is read directly from user input with no upper-bound clamp — a client can force the server to load and serialize an unbounded number of rows (memory/CPU exhaustion). Clamp it against a maximum (e.g. `Math.min(MAX_PAGE_SIZE, Number(req.query.limit))`). Suppress a vetted case with `// limit-ok`.",
      "suppress_marker": "limit-ok",
      "matcher": {
        "type": "line-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "any": [
          { "pattern": "\\b(take|limit)\\s*:\\s*\\+?\\s*(Number\\s*\\(\\s*)?req\\.(query|params|body)", "label": "take" }
        ],
        "snippet_max": 160
      }
    },
    {
      "id": "find-then-create-no-unique",
      "severity": "warning",
      "message": "A `findFirst`/`findOne`/`findUnique` read followed by `.create(` with no `connectOrCreate`, `upsert`, or `$transaction(` — a check-then-act race lets two concurrent requests both pass and create a duplicate row. Use a unique constraint plus `upsert`/`connectOrCreate`, or wrap the read+write in a transaction. Suppress a vetted case with `// find-create-ok`.",
      "suppress_marker": "find-create-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "patterns": [
          { "pattern": "\\.(findFirst|findOne|findUnique)\\s*\\(", "label": "read" },
          { "pattern": "\\.create\\s*\\(", "label": "create" }
        ],
        "trigger": "create",
        "absent": [
          { "pattern": "connectOrCreate|\\bupsert\\b|\\$transaction\\s*\\(", "label": "safe" }
        ],
        "snippet_max": 160
      }
    },
    {
      "id": "float-money-compare",
      "severity": "info",
      "message": "A money-named identifier (`price`/`amount`/`balance`/`fee`/`cost`) compared with `==`/`===`/`!=`/`!==` against a float literal (e.g. `price === 19.99`) — floating-point rounding error makes strict equality on monetary values unreliable. Represent money as integer minor units (cents) or a decimal library. Suppress a vetted case with `// money-ok`.",
      "suppress_marker": "money-ok",
      "matcher": {
        "type": "line-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "any": [
          { "pattern": "(?i)\\b(price|amount|balance|fee|cost)\\w*\\s*[!=]==?\\s*[0-9]+\\.[0-9]", "label": "ident-vs-float" },
          { "pattern": "(?i)[0-9]+\\.[0-9][0-9]*\\s*[!=]==?\\s*(price|amount|balance|fee|cost)\\w*", "label": "float-vs-ident" }
        ],
        "snippet_max": 160
      }
    },
    {
      "id": "empty-catch-on-write",
      "severity": "warning",
      "message": "A database write (`create`/`update`/`delete`/`upsert`/`updateMany`/`deleteMany`) appears in the same function as an empty `catch {}` block — the write's failure is caught and silently discarded, indistinguishable from success. Log or rethrow the error instead of swallowing it. Suppress a vetted case with `// empty-catch-ok`.",
      "suppress_marker": "empty-catch-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.(ts|tsx|js|mjs|cjs)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "skip_comment_lines": true,
        "patterns": [
          { "pattern": "\\.(create|update|delete|upsert|updateMany|deleteMany)\\s*\\(", "label": "write" },
          { "pattern": "catch\\s*(\\([^)]*\\))?\\s*\\{\\s*\\}", "label": "empty-catch" }
        ],
        "trigger": "empty-catch",
        "snippet_max": 160
      }
    }
  ]
}

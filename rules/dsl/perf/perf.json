{
  "id": "perf",
  "framework": "any",
  "schema_version": 1,
  "rules": [
    {
      "id": "api-in-loop",
      "severity": "warning",
      "message": "Network call made inside a loop (for/for-of/for-in/while/do, or an Array forEach/map/filter/reduce callback) — fires one request per iteration, the HTTP analogue of N+1 (rate-limit / serial-latency risk). Batch via a bulk endpoint, or gather inputs and issue one request (or a bounded Promise.all). Suppress a vetted case with `// api-in-loop-ok`.",
      "suppress_marker": "api-in-loop-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.(ts|tsx)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "require_file": "(?i)\\b(?:fetch|axios|got|ky|superagent|undici|wretch|ofetch|httpclient|httpservice|apiclient|fetcher|xhr|http|https|client|api|conn|session|agent|http2|net)\\b",
        "skip_comment_lines": true,
        "patterns": [
          {
            "pattern": "(?i)\\bfor\\s*(?:\\(|await\\b)|\\bwhile\\s*\\(|\\bdo\\s*\\{|\\.(?:forEach|map|filter|reduce)\\s*\\(",
            "label": "loop"
          },
          {
            "pattern": "(?i)\\b(?:fetch|\\$fetch|ofetch|got|ky|superagent|undici|wretch|axios)\\s*\\(|\\b(?:axios|http|https|httpClient|httpService|apiClient|api|client|fetcher|xhr|conn|session|agent|http2|net)\\.(?:get|post|put|patch|delete|head|options|request|fetch|send|query)\\s*\\(",
            "label": "network"
          }
        ],
        "trigger": "network",
        "absent": [
          {
            "pattern": "(?i)\\bretr(?:y|ies)\\b|\\bbackoff\\b|\\battempts?\\b",
            "label": "retry-guard"
          }
        ],
        "snippet_max": 160
      }
    }
  ]
}

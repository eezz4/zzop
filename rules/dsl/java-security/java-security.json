{
  "id": "java-security",
  "framework": "any",
  "schema_version": 1,
  "rules": [
    {
      "id": "sql-taint",
      "severity": "warning",
      "message": "SQL built by string concatenation — SQL injection risk. Use a parameterized/bound query (PreparedStatement `?`, JPA `:named` + setParameter). Suppress a vetted case with `// sql-taint-ok`.",
      "suppress_marker": "sql-taint-ok",
      "matcher": {
        "type": "line-scan",
        "file_pattern": "(?i)\\.(java|jsp|jspx|tag)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "require_file": "(?i)\\b(?:SELECT|INSERT|UPDATE|DELETE|MERGE)\\b",
        "skip_comment_lines": true,
        "line_pattern": "(?i)(?:\"[^\"]*(?:SELECT[^\"]*\\bFROM\\b|DELETE\\s+FROM\\b|INSERT\\s+INTO\\b|MERGE\\s+INTO\\b)[^\"]*\"|\"\\s*UPDATE\\b[^\"]*\")\\s*\\+\\s*[A-Za-z_$]",
        "snippet_max": 160
      }
    },
    {
      "id": "weak-crypto",
      "severity": "warning",
      "message": "Weak/deprecated cryptography — MD5·SHA-1·DES·RC4·ECB are broken. Use SHA-256+/AES-GCM; for passwords use bcrypt/PBKDF2/Argon2. Suppress a vetted case with `// weak-crypto-ok`.",
      "suppress_marker": "weak-crypto-ok",
      "matcher": {
        "type": "line-scan",
        "file_pattern": "(?i)\\.(java|jsp|jspx|tag)$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "require_file": "\\b(?:MessageDigest|DigestUtils|Cipher)\\b",
        "skip_comment_lines": true,
        "any": [
          { "pattern": "(?i)\\bMessageDigest\\.getInstance\\(\\s*\"(?:MD5|MD2|SHA-?1)\"", "label": "weak hash (MD5/SHA-1)" },
          { "pattern": "(?i)\\bDigestUtils\\.(?:md5|md2|sha1)\\w*", "label": "weak hash (MD5/SHA-1)" },
          { "pattern": "(?i)\\bCipher\\.getInstance\\(\\s*\"(?:DES|RC4|RC2)(?:[\"/])", "label": "weak cipher (DES/RC4/RC2)" },
          { "pattern": "(?i)\\bCipher\\.getInstance\\(\\s*\"[^\"]*/ECB/", "label": "ECB mode (no diffusion)" }
        ],
        "snippet_max": 160
      }
    },
    {
      "id": "cmd-injection",
      "severity": "warning",
      "message": "Method runs an external process (Runtime.exec / ProcessBuilder) and builds the command by string concatenation — command-injection risk. Pass arguments as an array element per token and validate/allow-list any user-controlled part. Suppress a vetted case with `// cmd-injection-ok`.",
      "suppress_marker": "cmd-injection-ok",
      "matcher": {
        "type": "method-scan",
        "file_pattern": "(?i)\\.java$",
        "file_exclude_pattern": "(?i)((^|/)(e2e|tests?|__tests?__|spec|fixtures?|testing)/|\\.(test|spec)\\.|\\.stories\\.|[.-]spec\\.|(^|/)\\.storybook/|(^|/)(playwright|vitest|jest|cypress|vite)\\.config\\.)",
        "require_file": "\\b(?:exec|ProcessBuilder)\\b",
        "skip_comment_lines": true,
        "patterns": [
          { "pattern": "\\b(?:exec|ProcessBuilder)\\b", "label": "exec" },
          { "pattern": "\"[^\"]*\"\\s*\\+\\s*[A-Za-z_$]", "label": "concat" }
        ],
        "trigger": "concat",
        "snippet_max": 160
      }
    }
  ]
}

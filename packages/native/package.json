  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node",
    "rules/"
  ],
  "scripts": {
    "smoke": "node smoke.mjs",
    "sync-versions": "node scripts/sync-versions.mjs",
    "prepack": "node scripts/copy-rules.mjs"
  },
  "optionalDependencies": {
    "@zzop/native-win32-x64-msvc": "0.0.0",
    "@zzop/native-darwin-x64": "0.0.0",
    "@zzop/native-darwin-arm64": "0.0.0",
    "@zzop/native-linux-x64-gnu": "0.0.0",
    "@zzop/native-linux-arm64-gnu": "0.0.0"
  }
}
